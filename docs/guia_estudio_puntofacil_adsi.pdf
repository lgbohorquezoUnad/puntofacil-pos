(- generate_password.py: genera hashes bcrypt.) Tj
T*
(- fix_admin_hash.py: actualiza el hash del administrador en MySQL.) Tj
T*
(- .python-version: archivo auxiliar de version.) Tj
T*
(- api_stdout.log / api_stderr.log: archivos de depuracion.) Tj
T*
() Tj
T*
(backend/routes/) Tj
T*
(- auth_routes.py: POST /api/login.) Tj
T*
(- product_routes.py: productos, categorias, dashboard, inventario, compras, conteos,) Tj
T*
(  transferencias y auditoria.) Tj
T*
(- sale_routes.py: ventas.) Tj
T*
(- cash_register_routes.py: abrir, cerrar y consultar caja.) Tj
T*
(- user_routes.py: CRUD de usuarios.) Tj
T*
() Tj
T*
(backend/controllers/) Tj
T*
(- auth_controller.py: valida credenciales y genera el token.) Tj
T*
(- product_controller.py: CRUD de productos, categorias y dashboard.) Tj
T*
(- sale_controller.py: valida y registra ventas.) Tj
T*
(- cash_register_controller.py: controla caja.) Tj
T*
(- inventory_controller.py: filtros, ajustes y movimientos.) Tj
T*
(- advanced_inventory_controller.py: compras, recepcion, conteos, transferencias,) Tj
T*
(  auditoria y dashboard financiero.) Tj
T*
(- user_controller.py: gestiona usuarios y roles.) Tj
T*
() Tj
T*
(backend/models/) Tj
T*
(- user_model.py: buscar, listar, crear, actualizar y eliminar usuarios.) Tj
T*
(- product_model.py: consultar categorias y productos; CRUD de productos.) Tj
T*
(- sale_model.py: transaccion de venta, detalle y descuento de stock.) Tj
T*
(- cash_register_model.py: apertura/cierre de caja y diferencia.) Tj
T*
(- inventory_model.py: resumenes, ajustes y trazabilidad en inventory_movements.) Tj
T*
(- advanced_inventory_model.py: compras, lotes, transferencias, conteos y auditoria.) Tj
T*
() Tj
T*
(frontend/) Tj
T*
(- index.html: redirige a /login.) Tj
T*
(- templates/login.html: pantalla de inicio de sesion.) Tj
T*
(- templates/pos.html: pantalla de punto de venta.) Tj
T*
(- templates/admin.html: pantalla administrativa.) Tj
T*
(- templates/inventory.html: pantalla de control de inventario.) Tj
T*
(- templates/operativa.html: pantalla de procesos avanzados.) Tj
T*
() Tj
T*
(frontend/static/js/) Tj
T*
(- config.js: calcula la URL base de la API para local o produccion.) Tj
T*
(- auth.js: guarda token y usuario en localStorage y adjunta Authorization.) Tj
T*
(- login.js: controla el formulario de login y la redireccion segun rol.) Tj
T*
(- pos.js: productos, carrito, caja, pagos y checkout.) Tj
T*
(- admin.js: dashboard y CRUD de productos y usuarios.) Tj
T*
(- inventory.js: filtros, KPIs, movimientos, ajuste de stock y exportacion CSV.) Tj
T*
(- operativa.js: compras, recepcion, conteos, transferencias y auditoria.) Tj
T*
(- ui.js: toasts, alertas, confirmaciones, tema y modo visual.) Tj
ET
endstream
